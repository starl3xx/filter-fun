# Node
node_modules/
npm-debug.log*
.npm/
.env
.env.*
!.env.example
!.env.*.example

# Foundry
packages/contracts/cache/
packages/contracts/out/
packages/contracts/broadcast/
packages/contracts/.gas-snapshot
packages/contracts/lib/
# Test sandboxes — Deploy.t.sol writes here so it doesn't clobber the real manifest.
packages/contracts/deployments/*.test.json
# RedeployFactory.s.sol archives the prior manifest here during its happy-path test.
packages/contracts/deployments/archive/

# Ponder (regenerated by `ponder dev`/`codegen`)
packages/indexer/generated/
packages/indexer/.ponder/

# Editors / agent caches
.claude/
.vscode/
.idea/
*.swp
.DS_Store

# Build artifacts
dist/
build/
.next/
.turbo/

# Coverage
coverage/
lcov.info

# Track E corpus build artifacts (transient state — corpus.csv + REPORT.md
# + discovered_tokens.csv are checked in as the deliverable)
track-e/.env
track-e/.fetch_state.json
track-e/.fetch_cache/
track-e/.venv/
track-e/__pycache__/
track-e/*.pyc
