# Base Sepolia genesis-deploy environment.
# Copy to .env.sepolia (gitignored) and fill in PRIVATE_KEY.
# Source it before running forge script:
#   source packages/contracts/.env.sepolia
#   forge script script/DeployGenesis.s.sol --rpc-url $BASE_RPC_URL --broadcast

# REQUIRED — supply your own ↓
PRIVATE_KEY=0x...                                 # deployer EOA private key (NEVER commit)

# Pre-filled — Base Sepolia canonical addresses
BASE_RPC_URL=https://sepolia.base.org
BASE_WETH=0x4200000000000000000000000000000000000006
V4_POOL_MANAGER=0x05E73354cFDd6745C338b50BcFDfA3Aa6fA03408

# Pre-mined for FilterHook (script/MineHookSalt.s.sol output).
# Hook will land at 0x71967bb8DC58C24B362EfD0869284Ff5685CCA00 (flag bits 0xA00 ✓).
HOOK_SALT=0x00000000000000000000000000000000000000000000000000000000000087e8

# Operational addresses — for testnet, reusing the deployer EOA everywhere is fine.
# Replace with real multisigs / treasury wallets before mainnet.
ORACLE_MULTISIG=0x58a585909ccCd4f84EBc3868db6dA8d9882fEe9C
MECHANICS_WALLET=0x58a585909ccCd4f84EBc3868db6dA8d9882fEe9C
POL_RECIPIENT=0x58a585909ccCd4f84EBc3868db6dA8d9882fEe9C
TREASURY_PROPOSER_0=0x58a585909ccCd4f84EBc3868db6dA8d9882fEe9C
TREASURY_PROPOSER_1=0x58a585909ccCd4f84EBc3868db6dA8d9882fEe9C
TREASURY_PROPOSER_2=0x58a585909ccCd4f84EBc3868db6dA8d9882fEe9C
