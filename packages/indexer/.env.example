# Network selection — pin one Ponder instance to one chain. Default "base" (mainnet);
# override to "baseSepolia" for testnet deploys.
PONDER_NETWORK=base

# RPC URLs — only the chain matching PONDER_NETWORK is actually used.
PONDER_RPC_URL_8453=https://mainnet.base.org
PONDER_RPC_URL_84532=https://sepolia.base.org

# Deployed contract addresses — fill in post-deploy
FILTER_LAUNCHER_ADDRESS=0x0000000000000000000000000000000000000000
FILTER_FACTORY_ADDRESS=0x0000000000000000000000000000000000000000
FILTER_HOOK_ADDRESS=0x0000000000000000000000000000000000000000
BONUS_DISTRIBUTOR_ADDRESS=0x0000000000000000000000000000000000000000

# Block at which the launcher was deployed (start of indexing)
DEPLOY_BLOCK=0

# Audit H-6 (Phase 1, 2026-05-01): CORS allow-list for browser clients hitting the
# indexer API. Comma-separated list of full origins (scheme + host + port). When unset,
# falls back to the default list baked into src/api/cors.ts:
#   https://filter.fun, https://docs.filter.fun, http://localhost:3000, http://localhost:3001
# Override here without a code deploy when adding a staging URL or new dev port.
# Empty entries (trailing commas) are dropped silently.
CORS_ALLOWED_ORIGINS=

# Epic 1.21 / spec §47.2 — Operator Admin Console allow-list. Comma-separated
# Ethereum addresses authorised to access /operator/* endpoints. Each request
# must carry a SIWE-style signed message (Authorization: Bearer <sig>,
# X-Operator-Address, X-Operator-Message, X-Operator-Issued-At ≤ 5min stale)
# whose recovered signer matches an entry here. Mainnet bring-up: set to the
# protocol multisig address; v2 will move to an on-chain `OperatorRegistry`.
# Genesis testnet: Jake's signing wallet
# (0x0Fc0F78fc939606db65F5BBF2F3715262C0b2F6E).
# Without this set, every /operator/* request returns 403 with reason
# "no_allowlist" — the console will render its setup banner.
OPERATOR_WALLETS=
