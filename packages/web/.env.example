# Chain selection — defaults to "base-sepolia". Set to "base" for mainnet.
NEXT_PUBLIC_CHAIN=base-sepolia

# Optional RPC overrides. Without these, viem falls back to the chain's public RPC.
NEXT_PUBLIC_BASE_RPC_URL=
NEXT_PUBLIC_BASE_SEPOLIA_RPC_URL=

# Indexer HTTP API base URL — sources /season, /tokens, /events for /arena.
# Production canonical: https://api.filter.fun
# Local dev with `npm --workspace @filter-fun/indexer run dev`: http://localhost:42069
NEXT_PUBLIC_INDEXER_URL=http://localhost:42069

# WalletConnect v2 project ID — provision at https://cloud.walletconnect.com.
# Required for the WalletConnect connector (mobile wallets via QR pairing).
# Without it, WC silently fails at pair time — the connector mounts in the
# modal but `connect()` rejects. Audit H-Web-1 (Phase 1, 2026-05-01):
# production deploys MUST set this.
NEXT_PUBLIC_WC_PROJECT_ID=

# Metadata pinning — server-side only. The /api/metadata route accepts
# launch-form fields, validates them, and pins the resulting JSON document
# either to Pinata (preferred) or to the filesystem (fallback). Set ONE of
# the two backends below; the route fails loudly if neither is configured.
#
# Audit M-Sec-1 (Phase 1, 2026-05-03): PINATA_JWT is server-only — never
# prefix it with `NEXT_PUBLIC_`. The Next.js bundler exposes any
# `NEXT_PUBLIC_*` env var to the browser bundle, which would leak the JWT
# to every visitor and let any client mint pins against your Pinata
# account. The keys below intentionally omit a `NEXT_PUBLIC_` variant so a
# copy-paste accident can't introduce one.
#
# Pinata JWT — preferred backend; pins JSON at api.pinata.cloud and the
# route returns `ipfs://<cid>`. Generate at https://app.pinata.cloud →
# API Keys with the `pinning` scope.
PINATA_JWT=

# Filesystem fallback — used only when PINATA_JWT is absent. Writes one
# `<uuid>.json` per pin under this directory; the route returns a self-
# hosted `https://<host>/api/metadata/<uuid>` URL that the indexer + token
# pages consume. Suitable for testnet / preview deploys; production should
# always set PINATA_JWT instead.
METADATA_STORE_DIR=

# Public origin for the filesystem fallback — used to build the returned
# `https://<host>/api/metadata/<uuid>` URL. Defaults to the request's own
# origin when unset, which is the right default for single-host deploys.
METADATA_PUBLIC_URL=
