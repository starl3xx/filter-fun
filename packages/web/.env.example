# Chain selection — defaults to "base-sepolia". Set to "base" for mainnet.
NEXT_PUBLIC_CHAIN=base-sepolia

# Optional RPC overrides. Without these, viem falls back to the chain's public RPC.
NEXT_PUBLIC_BASE_RPC_URL=
NEXT_PUBLIC_BASE_SEPOLIA_RPC_URL=

# Indexer HTTP API base URL — sources /season, /tokens, /events for /arena.
# In dev with `npm --workspace @filter-fun/indexer run dev`, the default works as-is.
NEXT_PUBLIC_INDEXER_URL=http://localhost:42069
