# Chain selection — defaults to "base-sepolia". Set to "base" for mainnet.
NEXT_PUBLIC_CHAIN=base-sepolia

# Optional RPC overrides. Without these, viem falls back to the chain's public RPC.
NEXT_PUBLIC_BASE_RPC_URL=
NEXT_PUBLIC_BASE_SEPOLIA_RPC_URL=

# Indexer HTTP API base URL — sources /season, /tokens, /events for /arena.
# Production canonical: https://api.filter.fun
# Local dev with `npm --workspace @filter-fun/indexer run dev`: http://localhost:42069
NEXT_PUBLIC_INDEXER_URL=http://localhost:42069

# WalletConnect v2 project ID — provision at https://cloud.walletconnect.com.
# Required for the WalletConnect connector (mobile wallets via QR pairing).
# Without it, WC silently fails at pair time — the connector mounts in the
# modal but `connect()` rejects. Audit H-Web-1 (Phase 1, 2026-05-01):
# production deploys MUST set this.
NEXT_PUBLIC_WC_PROJECT_ID=
